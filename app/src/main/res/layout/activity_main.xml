<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Test Mode"
        android:textSize="24sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/uriEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/test_mode_hint"
        android:inputType="textUri"
        android:text="spotify:playlist:37i9dQZF1DXcBWIGoYBMwo"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/triggerButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/test_mode_button"
        android:layout_gravity="center_horizontal"/>

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:layout_gravity="center_horizontal"
        android:text="Waiting for NFC or Test trigger..."/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Your Device SHA1 (for Spotify Dashboard):"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal" />

    <TextView
        android:id="@+id/sha1TextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textIsSelectable="true"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="#EEEEEE"
        android:text="Loading SHA1..."/>

</LinearLayout>
